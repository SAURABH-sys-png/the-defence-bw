---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

// Import all blog files from the blogs directory
const blogModules = import.meta.glob('./blogs/*.md', { eager: true });

// Transform the modules into a usable format with proper URLs
const allBlogs = Object.entries(blogModules).map(([path, module]: [string, any]) => {
  // Extract filename from path (e.g., './blogs/my-blog.md' -> 'my-blog')
  const filename = path.replace('./blogs/', '').replace('.md', '');
  
  return {
    ...module,
    url: `/blogs/${filename}/`,
    // Ensure frontmatter is accessible
    frontmatter: module.frontmatter || {}
  };
}).sort((a, b) => {
  // Sort by publication date (newest first)
  const dateA = new Date(a.frontmatter?.pubDate || 0).getTime();
  const dateB = new Date(b.frontmatter?.pubDate || 0).getTime();
  return dateB - dateA;
});

const recentBlogs = allBlogs.slice(0, 6);
---

<Layout 
  title="Home" 
  description="Empowering defense aspirants with accurate eligibility calculators, previous year question papers, insightful blogs, and real SSB recommendation success stories."
>
  <div class="mx-auto max-w-full px-4 py-8 sm:px-6 lg:px-12">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">

      <main class="lg:col-span-8 order-1 lg:order-2 space-y-12">
        <section class="space-y-6">
          <div>
            <h2 class="text-2xl font-bold tracking-tight text-slate-900">Latest Logs & Updates</h2>
            <p class="text-xs text-slate-500 mt-1">Chronological brief updates and insights compiled directly from the archives.</p>
          </div>

          <div class="space-y-4">
            {recentBlogs.length > 0 ? (
              recentBlogs.map((post) => (
                <article class="group relative flex flex-col justify-between rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md transition-all">
                  <div>
                    <div class="flex items-center gap-x-2 text-xs text-slate-400">
                      <time datetime={post.frontmatter?.pubDate}>
                        {post.frontmatter?.pubDate ? new Date(post.frontmatter.pubDate).toLocaleDateString('en-IN', {
                          day: 'numeric',
                          month: 'short',
                          year: 'numeric'
                        }) : 'No Date'}
                      </time>
                      {post.frontmatter?.author && (
                        <>
                          <span>•</span>
                          <span>{post.frontmatter.author}</span>
                        </>
                      )}
                    </div>
                    <h3 class="mt-2 text-lg font-bold text-slate-900 group-hover:text-blue-600 transition-colors">
                      <a href={post.url}>
                        <span class="absolute inset-0" />
                        {post.frontmatter?.title || 'Untitled Post'}
                      </a>
                    </h3>
                    <p class="mt-2 text-xs text-slate-500 line-clamp-2 leading-relaxed">
                      {post.frontmatter?.description || "Click to open and read the complete strategy breakdown details for this entry."}
                    </p>
                  </div>
                  <div class="mt-4 flex items-center text-xs font-semibold text-blue-600">
                    Read Breakdown <span class="ml-1 group-hover:translate-x-1 transition-transform">&rarr;</span>
                  </div>
                </article>
              ))
            ) : (
              <div class="rounded-xl border-2 border-dashed border-slate-200 p-8 text-center text-slate-400 text-sm">
                No blog logs found in <code class="bg-slate-100 px-1 rounded text-xs">./blogs/</code>. Add markdown files to populate this feed.
              </div>
            )}
          </div>
        </section>
      </main>

      <aside class="lg:col-span-2 order-3 space-y-6">
        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <h3 class="text-sm font-bold tracking-wider text-slate-900 uppercase mb-3 pb-2 border-b border-slate-100">
            All Available Logs
          </h3>
          {allBlogs.length > 0 ? (
            <ul class="space-y-3 max-h-80 overflow-y-auto pr-1 custom-scrollbar">
              {allBlogs.map((post) => (
                <li>
                  <a href={post.url} class="group block text-xs hover:text-blue-600 transition-colors">
                    <span class="block text-slate-400 font-medium text-[10px]">
                      {post.frontmatter?.pubDate ? new Date(post.frontmatter.pubDate).toLocaleDateString('en-IN', {
                        day: '2-digit',
                        month: 'short'
                      }) : 'N/A'}
                    </span>
                    <span class="text-slate-700 font-semibold group-hover:text-blue-600 line-clamp-1">
                      {post.frontmatter?.title || 'Untitled Post'}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-xs text-slate-400 italic">No logs compiled yet.</p>
          )}
        </div>

        
      </aside>

    </div>
  </div>

  <section class="bg-slate-900 text-white py-12 mt-12">
    <div class="mx-auto max-w-full px-4 text-center sm:px-6 lg:px-12">
      <h2 class="text-xl font-bold tracking-tight sm:text-2xl">Built for those who value precise metrics.</h2>
      <p class="mx-auto mt-2 max-w-xl text-xs text-slate-400">
        No dynamic algorithmic clutter or distracting loops. Just clean layouts, lightning-fast pages, and accurate, standard entry tracking resources.
      </p>
    </div>
  </section>
</Layout>