---
// src/components/Header.astro
---

<header
  class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/80 backdrop-blur-md"
>
  <div
    class="mx-auto flex h-16 max-w-full items-center justify-between px-4 sm:px-6 lg:px-12"
  >
    <div class="flex">
      <a href="/" class="flex items-center space-x-2">
        <span class="text-xl font-black tracking-tight text-slate-900">
          Defence<span class="text-blue-600">Roger</span>
        </span>
      </a>
    </div>

    <nav
      class="hidden md:flex items-center space-x-8 text-sm font-bold text-slate-600"
    >
      <a href="/" class="transition-colors hover:text-blue-600">Home</a>
      <a href="/calculator" class="transition-colors hover:text-blue-600"
        >Eligibility Calculator</a
      >
      <a href="/pyqs" class="transition-colors hover:text-blue-600"
        >PYQs & Papers</a
      >
      <a href="/stories" class="transition-colors hover:text-blue-600"
        >SSB Stories</a
      >
      <a href="/about" class="transition-colors hover:text-blue-600">About Us</a
      >
    </nav>

    <div class="flex md:hidden">
      <input type="checkbox" id="menu-toggle" class="peer hidden" />

      <label
        for="menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 text-slate-500 hover:bg-slate-100 hover:text-slate-700 cursor-pointer select-none"
      >
        <span class="sr-only">Open main menu</span>
        <svg
          class="h-6 w-6 peer-checked:hidden block"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </label>

      <div
        class="absolute left-0 right-0 top-16 z-40 hidden peer-checked:block border-b border-slate-200 bg-white p-4 shadow-lg transition-all duration-200"
      >
        <nav
          class="flex flex-col space-y-4 text-base font-medium text-slate-600"
        >
          <a href="/" class="rounded-lg px-3 py-2 hover:bg-slate-50 hover:text-blue-600">Home</a>
          <a href="/calculator" class="rounded-lg px-3 py-2 hover:bg-slate-50 hover:text-blue-600">Eligibility Calculator</a>
          <a href="/pyqs" class="rounded-lg px-3 py-2 hover:bg-slate-50 hover:text-blue-600">PYQs & Papers</a>
          <a href="/stories" class="rounded-lg px-3 py-2 hover:bg-slate-50 hover:text-blue-600">SSB Stories</a>
          <a href="/about" class="rounded-lg px-3 py-2 hover:bg-slate-50 hover:text-blue-600">About Us</a>
        </nav>
      </div>
    </div>
  </div>
</header>